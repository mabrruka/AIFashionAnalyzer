-/* DARK MODE */
-/* ===================== */
-
-body.dark-mode {
-    background: #0f0f0f;
-    color: #f5f5f5;
-}
-
-/* RIGHT PANEL */
-body.dark-mode .right {
-    background: #0f0f0f;
-    color: #f5f5f5;
-}
-
-/* INPUTS */
-body.dark-mode input {
-    background: #1e1e1e;
-    color: white;
-    border: 1px solid #333;
-}
-
-/* TABS */
-body.dark-mode .tab {
-    background: #2a2a2a;
-    color: white;
-}
-
-body.dark-mode .tab.active {
-    background: white;
-    color: black;
-}
-
-/* BUTTON */
-body.dark-mode .submit-btn {
-    background: white;
-    color: black;
-}
-
-/* TEXT */
-body.dark-mode .subtitle,
-body.dark-mode .footer {
-    color: #aaa;
