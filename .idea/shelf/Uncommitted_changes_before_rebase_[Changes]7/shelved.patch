-.section {
-    margin-top: 60px;
-}
-
-.section-title {
-    font-size: 26px;
-    margin-bottom: 20px;
-    opacity: 1; /* IMPORTANT FIX */
-}
-
-/* PILLS */
-.pill-scroll {
-    display: flex;
-    gap: 10px;
-    overflow-x: auto;
-}
-
-.pill {
-    background: #eee;
-    padding: 10px 16px;
-    border-radius: 999px;
-    white-space: nowrap;
-}
-
