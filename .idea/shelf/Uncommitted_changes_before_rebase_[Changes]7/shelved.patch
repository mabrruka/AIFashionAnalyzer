-.circle-wrap {
-    position: relative;
-    width: 160px;
-    height: 160px;
-    margin: 25px auto;
-}
-
-.circle {
-    transform: rotate(-90deg);
-    width: 160px;
-    height: 160px;
-}
-
-.circle circle {
-    fill: none;
-    stroke-width: 10;
-}
-
-.bg {
-    stroke: #ddd;
-}
-
-.progress {
-    stroke: black;
-    stroke-dasharray: 326;
-    stroke-dashoffset: 26;
-}
-
-.circle-text {
-    position: absolute;
-    top: 50%;
-    left: 50%;
-    transform: translate(-50%, -50%);
-    font-size: 38px;
-    font-weight: bold;
-}
-
