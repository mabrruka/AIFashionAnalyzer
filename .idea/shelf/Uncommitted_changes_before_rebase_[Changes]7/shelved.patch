-/* RIGHT SIDE */
-.right {
-    flex: 1;
-    display: flex;
-    flex-direction: column;
-    justify-content: center;
-    padding: 80px 70px;
-    position: relative;
-    background: #fff;
-    transition: background 0.3s, color 0.3s;
-}
-
-/* TOP BAR */
-.top-bar {
-    position: absolute;
-    top: 20px;
-    right: 20px;
-}
-
-.theme-btn {
-    border: none;
-    background: transparent;
-    font-size: 20px;
-    cursor: pointer;
-}
-
-/* LOGO */
-.logo {
-    font-size: 52px;
-    margin: 0;
-    letter-spacing: -1px;
-}
-
-.subtitle {
-    color: gray;
-    margin-bottom: 30px;
-}
-
-/* TABS */
-.tabs {
-    display: flex;
-    gap: 10px;
-    margin-bottom: 25px;
-}
-
-.tab {
-    flex: 1;
-    padding: 12px;
-    border: none;
-    cursor: pointer;
-    background: #eee;
-    border-radius: 10px;
-    transition: 0.2s;
-}
-
-.tab.active {
-    background: black;
-    color: white;
-}
-
-/* FORM */
-form {
-    display: flex;
-    flex-direction: column;
-    gap: 14px;
-}
-
-input {
-    padding: 14px;
-    border: 1px solid #ccc;
-    border-radius: 10px;
-    font-size: 14px;
-}
-
-/* ROW */
-.row {
-    display: flex;
-    gap: 10px;
-}
-
-.row input {
-    flex: 1;
-}
-
-/* BUTTON */
-.submit-btn {
-    padding: 14px;
-    background: black;
-    color: white;
-    border: none;
-    border-radius: 10px;
-    cursor: pointer;
-    font-size: 14px;
-}
-
-/* ERROR */
-.error {
-    color: red;
-    font-size: 13px;
-}
-
-/* FOOTER */
-.footer {
-    margin-top: 20px;
-    font-size: 12px;
-    color: gray;
-}
-
-/* DESKTOP IMAGE */
-@media (min-width: 900px) {
-    .left {
-        display: block;
-        flex: 1.6;
-    }
-}
-
-/* MOBILE */
-@media (max-width: 900px) {
-    .right {
-        padding: 40px 25px;
-    }
-}
-
