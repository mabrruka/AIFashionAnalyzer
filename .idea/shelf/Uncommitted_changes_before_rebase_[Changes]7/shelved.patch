-    padding: 60px;
-    gap: 60px;
-    box-sizing: border-box;
-}
-
-/* LEFT SIDE (TEXT + BUTTONS) */
-.leftPanel {
-    flex: 1;
-    display: flex;
-    flex-direction: column;
-    justify-content: center;
-}
-
-h1 {
-    font-size: 42px;
-    margin-bottom: 10px;
-}
-
-.subtitle {
-    font-size: 15px;
-    color: #9a9a9a;
-    margin-bottom: 40px;
-}
-
-/* RIGHT SIDE (OPTIONS) */
-.rightPanel {
-    flex: 1.2;
-    display: flex;
-    flex-direction: column;
-    justify-content: center;
-}
-
-/* GRID */
-.optionGrid {
-    display: grid;
-    grid-template-columns: 1fr 1fr;
-    gap: 18px;
-}
-
-/* BIG CARDS */
-.tile {
-    padding: 40px 25px;
-    border-radius: 18px;
-    border: 1px solid #e2e2e2;
-    font-size: 18px;
-    cursor: pointer;
-    text-align: center;
-    transition: 0.2s ease;
-    background: white;
-}
-
-.tile:hover {
-    border-color: black;
-    transform: translateY(-3px);
-}
-
-/* ACTIVE */
-.active {
-    border: 2px solid black !important;
-    background: #f6f6f6;
-}
-
-/* OTHER INPUT */
-.otherBox {
-    margin-top: 20px;
-    width: 100%;
-    padding: 14px;
-    border-radius: 12px;
-    border: 1px solid #ddd;
-    background: #f4f4f4;
-    font-family: inherit;
-}
-
-/* BUTTONS LEFT SIDE */
-.buttons {
-    display: flex;
-    gap: 12px;
-    margin-top: 40px;
-}
-
-/* BUTTON BASE */
-.buttons button {
-    padding: 14px 22px;
-    border-radius: 12px;
-    border: none;
-    font-size: 15px;
-    cursor: pointer;
-}
-
-/* BACK */
-.backBtn {
-    background: #e5e5e5;
-}
-
-/* CONTINUE */
-.continueBtn {
-    background: black;
-    color: white;
-}
-
-/* DISABLED */
-.continueBtn.disabled {
-    background: #cfcfcf;
-    color: #777;
-    cursor: not-allowed;
-}
